---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../site';
import { formatDate } from '../utils';

// Latest 3 of each, newest first, drafts excluded.
const published = <T extends { data: { draft: boolean; date: Date } }>(items: T[]) =>
  items
    .filter((i) => !i.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const recentPosts = published(await getCollection('blog')).slice(0, 3);
const recentReviews = published(await getCollection('reviews')).slice(0, 3);

// Edit these to reflect your real work / projects. Add a `url` to make a card a link.
const projects = [
  {
    title: 'goveranAI',
    description:
      'A WhatsApp-based AI marketplace connecting Zimbabwean farmers with buyers — plus Market Radar for early price signals.',
    url: 'https://www.goveranai.com/en',
  },
  {
    title: 'VhenekAI',
    description:
      'Offline-first, on-device AI bringing expert-level STEM education to underserved African communities.',
    url: 'https://vhenekai.org/',
  },
];
---

<BaseLayout>
  <section class="hero">
    <img class="hero__photo" src="/profile.jpg" alt={site.name} width="96" height="96" />
    <div>
      <h1>Hi, I'm Nyasha.</h1>
      <p class="hero__tagline">{site.tagline}</p>
    </div>
  </section>

  <p style="margin-top:1.5rem">
    I'm a data analyst with a chemical-engineering background and a self-taught grounding in
    machine learning. Right now I'm helping build production AI products while moving into
    AI safety. I read widely and write down what I learn — you'll find my
    <a href="/reviews">reviews</a> of books, papers and blogs, and my own
    <a href="/blog">writing</a> here, and my full background on
    <a href="/about">about</a>.
  </p>

  <h2>What I'm working on</h2>
  <div class="cards">
    {projects.map((p) => (
      <a class="card" href={p.url} target="_blank" rel="noopener noreferrer">
        <h3>{p.title}</h3>
        <p>{p.description}</p>
      </a>
    ))}
  </div>

  {recentPosts.length > 0 && (
    <>
      <h2>Latest writing</h2>
      <ul class="post-list">
        {recentPosts.map((post) => (
          <li>
            <div class="post-item__meta">
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
            </div>
            <h3 class="post-item__title"><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
            <p class="post-item__summary">{post.data.description}</p>
          </li>
        ))}
      </ul>
      <p><a href="/blog">All posts →</a></p>
    </>
  )}

  {recentReviews.length > 0 && (
    <>
      <h2>Recent reviews</h2>
      <ul class="post-list">
        {recentReviews.map((review) => (
          <li>
            <div class="post-item__meta">
              <span class="chip">{review.data.kind}</span>
              <time datetime={review.data.date.toISOString()}>{formatDate(review.data.date)}</time>
            </div>
            <h3 class="post-item__title"><a href={`/reviews/${review.id}`}>{review.data.title}</a></h3>
            <p class="post-item__summary">{review.data.summary}</p>
          </li>
        ))}
      </ul>
      <p><a href="/reviews">All reviews →</a></p>
    </>
  )}
</BaseLayout>
